<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Confirm Your New Email — Delivery Tracking Dz</title>
</head>
<body style="margin:0; padding:0; background-color:#eef2f7; font-family: 'Helvetica Neue', Arial, sans-serif; color:#0f172a;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#eef2f7; padding:40px 20px;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:14px; overflow:hidden; box-shadow:0 4px 14px rgba(15,23,42,0.08);">

          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #0b2545 0%, #13315c 100%); padding:32px 40px; text-align:center;">
              <div style="display:inline-block; background-color:#ff7a1a; width:48px; height:48px; border-radius:12px; line-height:48px; font-size:26px; margin-bottom:12px;">✉️</div>
              <h1 style="margin:0; color:#ffffff; font-size:22px; font-weight:700; letter-spacing:1.5px;">DELIVERY TRACKING <span style="color:#ff7a1a;">DZ</span></h1>
              <p style="margin:6px 0 0 0; color:#a8b6cc; font-size:12px; letter-spacing:2px; text-transform:uppercase;">Logistics ERP Platform</p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:48px 40px 32px 40px;">
              <h2 style="margin:0 0 16px 0; font-size:24px; font-weight:600; color:#0b2545;">Confirm your new email</h2>
              <p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#475569;">
                We received a request to update the email on your Delivery Tracking Dz account to <strong><%= email %></strong>. Please confirm this change using the code below or by clicking the button.
              </p>

              <!-- Activation code box -->
              <div style="background-color:#fff7ed; border:1px dashed #fdba74; border-radius:10px; padding:24px; text-align:center; margin:0 0 32px 0;">
                <p style="margin:0 0 8px 0; font-size:13px; text-transform:uppercase; letter-spacing:1px; color:#9a3412;">Confirmation code</p>
                <p style="margin:0; font-size:36px; font-weight:700; letter-spacing:8px; color:#9a3412; font-family:'Courier New', monospace;"><%= activation_number %></p>
              </div>

              <!-- CTA Button -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding:0 0 32px 0;">
                    <a href="<%= email_url %>" style="display:inline-block; background-color:#ff7a1a; color:#ffffff; text-decoration:none; padding:14px 36px; border-radius:8px; font-size:15px; font-weight:600; box-shadow:0 4px 10px rgba(255,122,26,0.35);">
                      Confirm New Email
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin:0 0 8px 0; font-size:13px; color:#64748b; line-height:1.6;">
                Or copy and paste this link into your browser:
              </p>
              <p style="margin:0 0 24px 0; font-size:13px; word-break:break-all;">
                <a href="<%= email_url %>" style="color:#13315c; text-decoration:underline;"><%= email_url %></a>
              </p>

              <div style="background-color:#fef2f2; border-left:4px solid #ef4444; padding:14px 18px; border-radius:6px; margin:24px 0 0 0;">
                <p style="margin:0; font-size:13px; color:#991b1b; line-height:1.6;">
                  ⚠️ If you did not request this change, secure your account immediately by changing your password and contacting your administrator.
                </p>
              </div>

              <p style="margin:24px 0 0 0; font-size:13px; color:#64748b; line-height:1.6;">
                This confirmation link expires in <strong>30 minutes</strong>.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f8fafc; padding:24px 40px; text-align:center; border-top:1px solid #e2e8f0;">
              <p style="margin:0 0 8px 0; font-size:12px; color:#64748b;">
                © <%= new Date().getFullYear() %> Delivery Tracking Dz. All rights reserved.
              </p>
              <p style="margin:0; font-size:12px; color:#94a3b8;">
                You're receiving this because someone requested an email change on your account.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
