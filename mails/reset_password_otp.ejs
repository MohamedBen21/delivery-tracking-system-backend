<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Password Reset</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
      background-color: #f7f7f7;
      padding: 20px;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-color: #ffffff;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 40px 20px;
      text-align: center;
      color: white;
    }
    .header h1 {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .header p {
      font-size: 14px;
      opacity: 0.95;
      font-weight: 500;
    }
    .content {
      padding: 40px 30px;
    }
    .greeting {
      font-size: 16px;
      color: #1f2937;
      margin-bottom: 24px;
      line-height: 1.6;
    }
    .greeting strong {
      color: #667eea;
    }
    .otp-section {
      background-color: #f3f4f6;
      border-left: 4px solid #667eea;
      padding: 24px;
      margin: 32px 0;
      border-radius: 6px;
      text-align: center;
    }
    .otp-label {
      font-size: 12px;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 12px;
      font-weight: 600;
    }
    .otp-code {
      font-size: 48px;
      font-weight: 700;
      color: #667eea;
      letter-spacing: 8px;
      font-family: 'Courier New', monospace;
      word-break: break-all;
    }
    .expiry-warning {
      background-color: #fef3c7;
      border: 1px solid #fcd34d;
      padding: 12px 16px;
      border-radius: 6px;
      margin-top: 20px;
      font-size: 13px;
      color: #92400e;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .warning-icon {
      font-size: 16px;
      flex-shrink: 0;
    }
    .instructions {
      background-color: #f0f9ff;
      border: 1px solid #bfdbfe;
      padding: 16px;
      border-radius: 6px;
      margin: 24px 0;
      font-size: 14px;
      color: #1e40af;
      line-height: 1.6;
    }
    .instructions strong {
      color: #1e3a8a;
    }
    .security-note {
      background-color: #f5f3ff;
      border-left: 4px solid #764ba2;
      padding: 16px;
      margin: 24px 0;
      border-radius: 4px;
      font-size: 13px;
      color: #5b21b6;
      line-height: 1.6;
    }
    .security-note strong {
      color: #4c1d95;
    }
    .footer {
      background-color: #f9fafb;
      padding: 24px 30px;
      border-top: 1px solid #e5e7eb;
      font-size: 12px;
      color: #6b7280;
      line-height: 1.8;
    }
    .footer-content {
      text-align: center;
      margin-bottom: 16px;
    }
    .brand {
      font-weight: 700;
      color: #667eea;
    }
    .divider {
      height: 1px;
      background-color: #e5e7eb;
      margin: 16px 0;
    }
    .footer-links {
      text-align: center;
      font-size: 11px;
    }
    .footer-links a {
      color: #667eea;
      text-decoration: none;
      margin: 0 8px;
    }
    .footer-links a:hover {
      text-decoration: underline;
    }
    @media (max-width: 600px) {
      .container {
        border-radius: 0;
        box-shadow: none;
      }
      .content {
        padding: 24px 16px;
      }
      .otp-code {
        font-size: 36px;
        letter-spacing: 4px;
      }
      .header {
        padding: 30px 16px;
      }
      .header h1 {
        font-size: 24px;
      }
      .otp-section {
        padding: 20px 16px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <h1>🔐 Password Reset</h1>
      <p>Secure password recovery</p>
    </div>
    <!-- Content -->
    <div class="content">
      <p class="greeting">
        Hi <strong><%= firstName %></strong>,
      </p>
      <p style="font-size: 15px; color: #374151; margin-bottom: 24px; line-height: 1.6;">
        We received a request to reset your password. Use the code below to proceed with your password reset.
      </p>
      <!-- OTP Section -->
      <div class="otp-section">
        <div class="otp-label">Your Reset Code</div>
        <div class="otp-code"><%= otp %></div>
        <div class="expiry-warning">
          <span class="warning-icon">⏱️</span>
          <span>Code expires in <strong><%= expireMinutes %> minutes</strong></span>
        </div>
      </div>
      <!-- Instructions -->
      <div class="instructions">
        <strong>📋 Next Steps:</strong>
        <ol style="margin-left: 20px; margin-top: 8px;">
          <li>Enter this code in the password reset form</li>
          <li>Create a new, strong password</li>
          <li>Log in with your new password</li>
        </ol>
      </div>
      <!-- Security Note -->
      <div class="security-note">
        <strong>🛡️ Security Reminder:</strong> Never share this code with anyone. FENNEC staff will never ask for your OTP or password. If you didn't request this reset, ignore this email and your password will remain unchanged.
      </div>
      <p style="font-size: 14px; color: #6b7280; margin-top: 24px; line-height: 1.6;">
        If you didn't request a password reset, please ignore this email or contact our support team immediately.
      </p>
    </div>
    <!-- Footer -->
    <div class="footer">
      <div class="footer-content">
        <p>© 2024 <span class="brand">FENNEC</span> — Your Delivery Network</p>
        <div class="divider"></div>
        <p style="margin-bottom: 12px;">This is an automated message, please do not reply to this email.</p>
      </div>
      <div class="footer-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Contact Support</a>
      </div>
    </div>
  </div>
</body>
</html>